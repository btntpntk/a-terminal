// ============================================================
// MANSFIELD RS + MINERVINI TREND TEMPLATE  —  FIXED v5.1
// Weinstein Stage Analysis × Mark Minervini SEPA
// Fixes: (1) first-bar nz guard  (2) label placement stability
// ============================================================
//@version=5
indicator("Mansfield RS + Minervini [SET Weinstein]", overlay=true, max_labels_count=200)

// ── Inputs ──────────────────────────────────────────────────
grpRS  = "Mansfield RS"
grpMIN = "Minervini Template"
grpVIS = "Visuals"

benchmark = input.symbol("SET:SET",  "Benchmark Index",  group=grpRS,
     tooltip="SET:SET สำหรับหุ้นไทย\nSET:SET50 สำหรับ large-cap only")
maLen   = input.int(52,  "RS MA Length (weeks/bars)", minval=10, group=grpRS,
     tooltip="Daily chart ใช้ 260 | Weekly chart ใช้ 52")
smoothN = input.int(3,   "RS Smooth EMA",    minval=1, group=grpRS)

showMA    = input.bool(true, "Show MAs (50/150/200)", group=grpVIS)
showTempl = input.bool(true, "Show Template Score",    group=grpVIS)

// ── MA Calculations ──────────────────────────────────────────
ma50   = ta.sma(close, 50)
ma150  = ta.sma(close, 150)
ma200  = ta.sma(close, 200)

// ── 52-Week High/Low ──────────────────────────────────────────
high52 = ta.highest(high, 252)
low52  = ta.lowest(low,  252)

// ── Minervini 8 Conditions ───────────────────────────────────
bool c1 = close > ma150 and close > ma200
bool c2 = ma150 > ma200
bool c3 = ma200 > ma200[25]
bool c4 = ma50  > ma150 and ma50 > ma200
bool c5 = close > ma50
bool c6 = close >= low52  * 1.25
bool c7 = close >= high52 * 0.75
bool c8 = ma200 > ma200[1]

int  score   = (c1?1:0)+(c2?1:0)+(c3?1:0)+(c4?1:0)+(c5?1:0)+(c6?1:0)+(c7?1:0)+(c8?1:0)
bool passAll = score == 8

// ── Mansfield RS ─────────────────────────────────────────────
float bmClose = request.security(benchmark, timeframe.period, close)
float rs      = bmClose != 0 ? (close / bmClose) * 100 : na
float rsMA    = ta.sma(rs, maLen)
float mRS     = (not na(rsMA) and rsMA != 0) ? ((rs / rsMA) - 1) * 100 : na
float mRS_s   = ta.ema(nz(mRS), smoothN)       // ✅ fix: nz guard

// ── MA Plots ──────────────────────────────────────────────────
plot(showMA ? ma50  : na, "MA 50",  color.blue,                 1)
plot(showMA ? ma150 : na, "MA 150", color.new(color.orange, 10), 1)
plot(showMA ? ma200 : na, "MA 200", color.new(color.red,    10), 2)

// ── Background ───────────────────────────────────────────────
bgcolor(passAll and mRS_s > 0             ? color.new(color.lime,  90) :
        passAll                           ? color.new(color.yellow,94) :
        not passAll and mRS_s < 0         ? color.new(color.red,   96) : na)

// ── Template Score Label ──────────────────────────────────────
if showTempl and barstate.islast
    string scoreIcon = passAll ? "✅" : score >= 6 ? "🟡" : "❌"
    color labelCol   = passAll ? color.new(color.lime,40) :
                       score>=6 ? color.new(color.yellow,40) :
                                  color.new(color.red,50)
    label.new(bar_index, high * 1.01,
         scoreIcon + " " + str.tostring(score) + "/8  RS:" + str.tostring(math.round(nz(mRS_s),1)) + "%",
         style=label.style_label_down, color=labelCol,
         textcolor=color.white, size=size.small)

// ── Detail Table ──────────────────────────────────────────────
var table dash = table.new(position.top_left, 3, 10,
     bgcolor=color.new(color.black, 78), border_width=1, border_color=color.new(color.gray,50))

if barstate.islast
    color hCol = passAll ? color.new(color.lime,40) : score>=6 ? color.new(color.yellow,40) : color.new(color.red,50)
    table.cell(dash, 0, 0, "Minervini",              bgcolor=hCol, text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 0, str.tostring(score)+"/8", bgcolor=hCol, text_color=color.white, text_size=size.small)
    table.cell(dash, 2, 0, passAll?"PASS":"FAIL",    bgcolor=hCol, text_color=passAll?color.lime:color.red, text_size=size.small)

    conds  = array.from("P>MA150&200","MA150>MA200","MA200 up 5W","MA50>MA150&200","P>MA50","P≥Low52+25%","P≤High52-25%","MA200 rising")
    chkArr = array.from(c1,c2,c3,c4,c5,c6,c7,c8)
    for i = 0 to 7
        table.cell(dash, 0, i+1, str.tostring(i+1)+".", text_color=color.gray,   text_size=size.tiny)
        table.cell(dash, 1, i+1, array.get(conds,i),    text_color=color.silver, text_size=size.tiny)
        bool chk = array.get(chkArr, i)
        table.cell(dash, 2, i+1, chk?"✓":"✗", text_color=chk?color.lime:color.red, text_size=size.tiny)

// ── Alerts  (✅ fix: nz guard on [1]) ────────────────────────
bool newPass = passAll and not nz(passAll[1], false)
bool newFail = not passAll and nz(passAll[1], false)
alertcondition(newPass, "Minervini PASS",  "✅ Minervini Template: ALL 8 passed")
alertcondition(newFail, "Minervini BREAK", "⚠️ Minervini Template: Dropped from Stage 2")
