// ============================================================
// SET SWING DASHBOARD [7-Star Confluence Scorer]  —  FIXED v5.1
// Fixes: (1) type RowData ย้ายไป global scope (Pine บังคับ)
//        (2) float-as-bool ใน pivothigh (same bug as file #1)
//        (3) ceLS history access cleanup
// ============================================================
//@version=5
indicator("SET Swing Dashboard [7-Star Confluence]", overlay=false)

// ✅ fix: type ต้องประกาศที่ global scope
type RowData
    string name
    bool   pass
    string val
    string weight

// ── Pull in all calc inline ─────────────────────────────────
benchmark = input.symbol("SET:SET", "Benchmark (for RS)")

// ── MAs ──────────────────────────────────────────────────────
ma50   = ta.sma(close, 50)
ma150  = ta.sma(close, 150)
ma200  = ta.sma(close, 200)
high52 = ta.highest(high, 252)
low52  = ta.lowest(low,  252)

// ── 1. Weinstein Stage 2 ─────────────────────────────────────
bool stage2 = close > ma200 and ma200 > ma200[10] and close > ma150

// ── 2. Minervini (simplified 6/8 check) ─────────────────────
bool c1 = close > ma150 and close > ma200
bool c2 = ma150 > ma200
bool c3 = ma200 > ma200[25]
bool c4 = ma50  > ma150 and ma50 > ma200
bool c5 = close > ma50
bool c6 = close >= low52  * 1.25
bool c7 = close >= high52 * 0.75
bool c8 = ma200 > ma200[1]
int  score8    = (c1?1:0)+(c2?1:0)+(c3?1:0)+(c4?1:0)+(c5?1:0)+(c6?1:0)+(c7?1:0)+(c8?1:0)
bool minervini = score8 >= 6

// ── 3. Hurst Exponent (R/S, len=100) ─────────────────────────
int hurstLen = 100
float hurst = na
if bar_index >= hurstLen
    float mean = ta.sma(close, hurstLen)
    float maxC = -1e10
    float minC =  1e10
    float cumD = 0.0
    float sumSq= 0.0
    for i = 0 to hurstLen-1
        cumD  += close[i] - mean
        maxC  := math.max(maxC, cumD)
        minC  := math.min(minC, cumD)
        sumSq += math.pow(close[i] - mean, 2)
    float R = maxC - minC
    float S = math.sqrt(sumSq / hurstLen)
    if R > 0 and S > 0
        hurst := math.log(R/S) / math.log(hurstLen)
float hurstSmooth = ta.ema(nz(hurst, 0.5), 5)
bool  hurstTrend  = hurstSmooth > 0.52

// ── 4. PP Supertrend  (✅ fix: not na(ph2)) ─────────────────
int   prd = 2
float Fd  = 3.0
int   Pd2 = 10
float ph2 = ta.pivothigh(high, prd, prd)
float pl2 = ta.pivotlow(low,   prd, prd)
var float UP_   = na
var float DN_   = na
var float TUp_  = na
var float TDown_= na
var int   Tr    = 1
float atr2 = ta.atr(Pd2)
UP_ := not na(ph2) ? ph2 : nz(UP_[1])
DN_ := not na(pl2) ? pl2 : nz(DN_[1])
float Pv = na(UP_) or na(DN_) ? close : (UP_ + DN_)/2
TUp_   := na(TUp_[1])   ? Pv - Fd*atr2 : Pv > TUp_[1]   ? math.max(Pv - Fd*atr2, TUp_[1])   : Pv - Fd*atr2
TDown_ := na(TDown_[1]) ? Pv + Fd*atr2 : Pv < TDown_[1] ? math.min(Pv + Fd*atr2, TDown_[1]) : Pv + Fd*atr2
Tr := Pv > TDown_[1] ? 1 : Pv < TUp_[1] ? -1 : nz(Tr[1], 1)
bool ppstLong = Tr == 1

// ── 5. Laguerre RSI ──────────────────────────────────────────
float gam = 0.6
var float L0 = na
var float L1 = na
var float L2 = na
var float L3 = na
L0 := (1-gam)*close + gam*nz(L0[1])
L1 := -gam*L0       + nz(L0[1]) + gam*nz(L1[1])
L2 := -gam*L1       + nz(L1[1]) + gam*nz(L2[1])
L3 := -gam*L2       + nz(L2[1]) + gam*nz(L3[1])
float cu = (L0>L1?L0-L1:0)+(L1>L2?L1-L2:0)+(L2>L3?L2-L3:0)
float cd = (L0<L1?L1-L0:0)+(L1<L2?L2-L1:0)+(L2<L3?L3-L2:0)
float LaRSI2 = (cu+cd) != 0 ? cu / (cu+cd) : 0
bool larsiGood = LaRSI2 > 0.20 and LaRSI2 < 0.85

// ── 6. Chandelier Exit (simplified) ──────────────────────────
float ce_atr  = 3.0 * ta.atr(22)
float ceLS_   = ta.highest(close, 22) - ce_atr
var float ceLS_prev = na
ceLS_prev := nz(ceLS_[1], ceLS_)
float ceLong = close[1] > ceLS_prev ? math.max(ceLS_, ceLS_prev) : ceLS_
var int ceDir = 1
ceDir := close > nz(ceLong[1]) ? 1 : close < nz(ceLong[1]) ? -1 : nz(ceDir[1], 1)
bool chandLong = ceDir == 1

// ── 7. WVF Not Spiking (calm environment) ─────────────────────
float wvf2   = (ta.highest(close, 22) - low) / ta.highest(close, 22) * 100
bool  wvfCalm = wvf2 < 15

// ── CONFLUENCE SCORE ──────────────────────────────────────────
int confScore = (stage2?1:0)+(minervini?1:0)+(hurstTrend?1:0)+
                (ppstLong?1:0)+(larsiGood?1:0)+(chandLong?1:0)+(wvfCalm?1:0)

color confColor = confScore >= 6 ? color.lime :
                  confScore >= 4 ? color.yellow :
                  confScore >= 2 ? color.orange : color.red

string stars = confScore >= 6 ? "⭐⭐⭐⭐⭐⭐" :
               confScore >= 5 ? "⭐⭐⭐⭐⭐ " :
               confScore >= 4 ? "⭐⭐⭐⭐  " :
               confScore >= 3 ? "⭐⭐⭐   " :
               confScore >= 2 ? "⭐⭐    "  :
               confScore >= 1 ? "⭐     "   : "——    "

plot(confScore, "Confluence Score", confColor, 3, plot.style_columns)
hline(6, "Strong (6+)",  color.new(color.lime,30),   hline.style_dashed)
hline(4, "Moderate (4+)",color.new(color.yellow,40), hline.style_dashed)
hline(2, "Weak (2+)",    color.new(color.red,50),    hline.style_dotted)

bgcolor(confScore >= 6 ? color.new(color.lime,  88) :
        confScore >= 4 ? color.new(color.yellow,92) :
        confScore >= 2 ? color.new(color.orange,94) : color.new(color.red,96))

// ── Main Dashboard Table ──────────────────────────────────────
var table dash = table.new(position.top_right, 4, 10,
     bgcolor=color.new(color.black,72), border_width=1, border_color=color.new(color.gray,60))

if barstate.islast
    table.cell(dash, 0, 0, "SET SWING DASHBOARD", text_color=color.white, text_size=size.normal,
         bgcolor=color.new(confColor,30))
    table.cell(dash, 1, 0, "", bgcolor=color.new(confColor,30))
    table.cell(dash, 2, 0, stars, text_color=color.yellow, text_size=size.small, bgcolor=color.new(confColor,30))
    table.cell(dash, 3, 0, str.tostring(confScore)+"/7", text_color=confColor, text_size=size.normal,
         bgcolor=color.new(confColor,30))

    table.cell(dash, 0, 1, "Filter",   text_color=color.gray, text_size=size.tiny, bgcolor=color.new(color.black,50))
    table.cell(dash, 1, 1, "Status",   text_color=color.gray, text_size=size.tiny, bgcolor=color.new(color.black,50))
    table.cell(dash, 2, 1, "Value",    text_color=color.gray, text_size=size.tiny, bgcolor=color.new(color.black,50))
    table.cell(dash, 3, 1, "Weight",   text_color=color.gray, text_size=size.tiny, bgcolor=color.new(color.black,50))

    // ✅ fix: build array locally — type ประกาศไว้ global แล้ว
    array<RowData> rows = array.new<RowData>()
    array.push(rows, RowData.new("Weinstein Stage2",    stage2,     close>ma200?"Above MA200":"Below MA200", "Macro"))
    array.push(rows, RowData.new("Minervini (6+/8)",    minervini,  str.tostring(score8)+"/8",               "Template"))
    array.push(rows, RowData.new("Hurst Trending",      hurstTrend, str.tostring(math.round(hurstSmooth,3)), "Regime"))
    array.push(rows, RowData.new("PP Supertrend Long",  ppstLong,   ppstLong?"Long":"Short",                 "Trend"))
    array.push(rows, RowData.new("LaRSI (not OB)",      larsiGood,  str.tostring(math.round(LaRSI2,2)),      "Trigger"))
    array.push(rows, RowData.new("Chandelier Long",     chandLong,  chandLong?"Up":"Down",                   "Trailing"))
    array.push(rows, RowData.new("WVF Calm (<15)",      wvfCalm,    str.tostring(math.round(wvf2,1)),        "Fear"))

    for i = 0 to array.size(rows) - 1
        RowData r = array.get(rows, i)
        color  rc  = r.pass ? color.lime : color.red
        string ico = r.pass ? "✓" : "✗"
        table.cell(dash, 0, i+2, r.name,            text_color=color.silver, text_size=size.tiny)
        table.cell(dash, 1, i+2, ico+" "+(r.pass?"PASS":"FAIL"), text_color=rc, text_size=size.tiny,
             bgcolor=r.pass?color.new(color.lime,95):color.new(color.red,95))
        table.cell(dash, 2, i+2, r.val,             text_color=color.gray,   text_size=size.tiny)
        table.cell(dash, 3, i+2, r.weight,          text_color=color.new(color.gray,30), text_size=size.tiny)

// ── Alert ────────────────────────────────────────────────────
bool newHigh = confScore >= 6 and nz(confScore[1]) < 6
bool newLow  = confScore <= 2 and nz(confScore[1]) > 2
alertcondition(newHigh, "SET Confluence HIGH ≥6", "✅ Confluence 6+/7 — Strong swing setup")
alertcondition(newLow,  "SET Confluence LOW ≤2",  "⚠️ Confluence dropped ≤2 — Avoid or exit")
