// ============================================================
// LAGUERRE RSI [Ehlers DSP]  —  FIXED v5.1
// Original: John Ehlers "Cybernetic Analysis for Stocks & Futures"
// Fixes: (1) fill() signature — ใช้ plot-to-plot แทน mix plot+hline
// ============================================================
//@version=5
indicator("Laguerre RSI [Ehlers SET]", shorttitle="LaRSI", format=format.price, precision=3)

// ── Inputs ──────────────────────────────────────────────────
gamma   = input.float(0.6,  "Gamma (damping)",  minval=0.1, maxval=0.9, step=0.05,
          tooltip="ยิ่ง gamma สูง ยิ่ง smooth / lag มาก\nDaily: 0.5-0.7 | Weekly: 0.7-0.8")
obLevel = input.float(0.75, "Overbought Level", minval=0.5, maxval=0.99, step=0.05)
osLevel = input.float(0.25, "Oversold Level",   minval=0.01,maxval=0.5,  step=0.05)
src     = input.source(close, "Source")
showBg  = input.bool(true, "Show Background Color")

// ── Laguerre Filter (4-pole) ─────────────────────────────────
var float L0 = na
var float L1 = na
var float L2 = na
var float L3 = na

L0 := (1 - gamma) * src        + gamma * nz(L0[1])
L1 := -gamma      * L0         + nz(L0[1]) + gamma * nz(L1[1])
L2 := -gamma      * L1         + nz(L1[1]) + gamma * nz(L2[1])
L3 := -gamma      * L2         + nz(L2[1]) + gamma * nz(L3[1])

// ── RSI Calculation on Laguerre poles ────────────────────────
float cu = (L0>L1 ? L0-L1:0) + (L1>L2 ? L1-L2:0) + (L2>L3 ? L2-L3:0)
float cd = (L0<L1 ? L1-L0:0) + (L1<L2 ? L2-L1:0) + (L2<L3 ? L3-L2:0)
float LaRSI = (cu + cd) != 0 ? cu / (cu + cd) : 0

// ── Reference Lines ──────────────────────────────────────────
hOB  = hline(obLevel, "OB",   color.new(color.red,   40), hline.style_dashed)
hMid = hline(0.5,     "Mid",  color.new(color.gray,  60), hline.style_dotted)
hOS  = hline(osLevel, "OS",   color.new(color.green, 40), hline.style_dashed)
hTop = hline(1.0,     "Top",  display=display.none)
hBot = hline(0.0,     "Bot",  display=display.none)

// ── Plot ─────────────────────────────────────────────────────
color rsiCol = LaRSI >= obLevel ? color.red :
               LaRSI <= osLevel ? color.lime :
               LaRSI >= 0.5    ? color.new(color.orange, 20) :
                                  color.new(color.teal,  20)

plot(LaRSI, "Laguerre RSI", rsiCol, 2)

// ✅ fix: fill ต้องเป็น (hline,hline) ล้วน ไม่ mix plot+hline
fill(hOB, hTop, color.new(color.red,  80))      // OB zone shade
fill(hBot, hOS, color.new(color.lime, 80))      // OS zone shade

if showBg
    bgcolor(LaRSI >= obLevel ? color.new(color.red,  92) :
            LaRSI <= osLevel ? color.new(color.lime, 92) : na)

// ── Signals ──────────────────────────────────────────────────
bool longSig      = ta.crossover(LaRSI,  osLevel)
bool shortSig     = ta.crossunder(LaRSI, obLevel)
bool midCrossUp   = ta.crossover(LaRSI,  0.5)
bool midCrossDown = ta.crossunder(LaRSI, 0.5)

plotshape(longSig,     "Long Entry",  shape.triangleup,   location.bottom, color.lime,   size=size.tiny)
plotshape(shortSig,    "Short Entry", shape.triangledown, location.top,    color.red,    size=size.tiny)
plotshape(midCrossUp,  "Mid Up",      shape.circle,       location.bottom, color.orange, size=size.tiny)
plotshape(midCrossDown,"Mid Down",    shape.circle,       location.top,    color.orange, size=size.tiny)

// ── Dashboard ─────────────────────────────────────────────────
var table dash = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 75), border_width=1, border_color=color.gray)
if barstate.islast
    string zone = LaRSI >= obLevel ? "🔴 OB" : LaRSI <= osLevel ? "🟢 OS" : LaRSI >= 0.5 ? "⬆️ Above Mid" : "⬇️ Below Mid"
    color  zCol = LaRSI >= obLevel ? color.red : LaRSI <= osLevel ? color.lime : color.yellow
    table.cell(dash, 0, 0, "LaRSI",  text_color=color.white,  text_size=size.small)
    table.cell(dash, 1, 0, str.tostring(math.round(LaRSI,3)), text_color=rsiCol, text_size=size.small)
    table.cell(dash, 0, 1, "Zone",   text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 1, zone,     text_color=zCol,         text_size=size.tiny)
    table.cell(dash, 0, 2, "Gamma",  text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 2, str.tostring(gamma), text_color=color.gray, text_size=size.tiny)

// ── Alerts ───────────────────────────────────────────────────
alertcondition(longSig,      "LaRSI Long",     "🟢 LaRSI: Cross above OS")
alertcondition(shortSig,     "LaRSI Short",    "🔴 LaRSI: Cross below OB")
alertcondition(midCrossUp,   "LaRSI Mid Up",   "LaRSI cross above 0.5")
alertcondition(midCrossDown, "LaRSI Mid Down", "LaRSI cross below 0.5")
