// ============================================================
// WILLIAMS VIX FIX + CONNORS RSI-2  —  FIXED v5.1
// VixFix: Chris Moody (2014) — Synthetic VIX per symbol
// ConnorsRSI-2: Larry Connors
// Fixes: (1) var streak for persistent state
// ============================================================
//@version=5
indicator("WilliamsVixFix + RSI2 [SET Bottom Kit]", shorttitle="WVF+RSI2", format=format.price, precision=2)

// ── Williams Vix Fix Inputs ──────────────────────────────────
grpWVF = "Williams Vix Fix"
pd   = input.int(22,   "WVF LookBack Period (high)", minval=5,  group=grpWVF)
bbl  = input.int(20,   "Bollinger Band Length",       minval=5,  group=grpWVF)
mult = input.float(2.0,"BB Std Dev Multiplier",       minval=0.5,group=grpWVF, step=0.1)
lb   = input.int(50,   "Percentile LookBack",         minval=5,  group=grpWVF)
ph   = input.float(0.85,"Highest Percentile",         minval=0.5,maxval=0.99,group=grpWVF)

// ── ConnorsRSI Inputs ────────────────────────────────────────
grpCRSI = "Connors RSI-2"
rsi2Len = input.int(2,   "RSI Period",    minval=1,  group=grpCRSI)
strLen  = input.int(3,   "Streak Length", minval=1,  group=grpCRSI)
rankLen = input.int(100, "Rank Length",   minval=10, group=grpCRSI)
ma200L  = input.int(200, "Trend Filter (SMA)", minval=50, group=grpCRSI)

// ── WVF Calculation ──────────────────────────────────────────
float wvf = (ta.highest(close, pd) - low) / ta.highest(close, pd) * 100

float midBB   = ta.sma(wvf, bbl)
float sDev    = mult * ta.stdev(wvf, bbl)
float upperBB = midBB + sDev

float rangeHigh = ta.highest(wvf, lb) * ph

bool wvfSpike = wvf >= upperBB or wvf >= rangeHigh
bool wvfFired = (wvf[1] >= upperBB[1] or wvf[1] >= rangeHigh[1]) and
                 wvf < upperBB and wvf < rangeHigh

// ── Connors RSI-2 Calculation ────────────────────────────────
float rsi2 = ta.rsi(close, rsi2Len)

// ✅ fix: var ให้ streak ชัดเจน
var float streak = 0.0
if close > close[1]
    streak := streak[1] <= 0 ? 1 : streak[1] + 1
else if close < close[1]
    streak := streak[1] >= 0 ? -1 : streak[1] - 1
else
    streak := 0.0

float streakRSI = ta.rsi(streak, strLen)

// Percentile Rank of 1-day ROC
float roc1    = (close / close[1] - 1) * 100
float rankRaw = 0.0
for i = 1 to rankLen
    if roc1 >= roc1[i]
        rankRaw += 1
float rocRank = rankRaw / rankLen * 100

float cRSI = (rsi2 + streakRSI + rocRank) / 3

// ── Trend Filter ─────────────────────────────────────────────
float ma200val  = ta.sma(close, ma200L)
bool  aboveMa200 = close > ma200val

// ── Dual Confirm Signal ───────────────────────────────────────
bool longSignal = wvfFired and cRSI < 10 and aboveMa200
bool nearSignal = (wvfSpike or cRSI < 15) and aboveMa200

// ── Plots ─────────────────────────────────────────────────────
color wvfCol = wvfSpike ? color.lime : color.new(color.gray, 50)
hline(0,  "Zero",     color.gray, hline.style_dotted)
hline(15, "WVF Alert",color.new(color.red,50), hline.style_dashed)

plot(wvf,      "WVF",         wvfCol, 1, plot.style_columns)
plot(upperBB,  "BB Upper",    color.new(color.red,   50), 1)
plot(rangeHigh,"Range High",  color.new(color.orange,50), 1)
plot(cRSI,     "ConnorsRSI2", color.new(color.aqua,  20), 2)

hline(90, "CRSI OB", color.new(color.red,  70), hline.style_dotted)
hline(10, "CRSI OS", color.new(color.lime, 70), hline.style_dotted)

plotshape(longSignal, "STRONG Long", shape.triangleup, location.bottom,
     color.lime, size=size.normal, text="BUY")
plotshape(nearSignal and not longSignal, "Weak Long", shape.circle, location.bottom,
     color.yellow, size=size.tiny)

bgcolor(longSignal ? color.new(color.lime,  82) :
        wvfSpike   ? color.new(color.yellow,90) : na)

// ── Dashboard ─────────────────────────────────────────────────
var table dash = table.new(position.top_right, 2, 6,
     bgcolor=color.new(color.black,75), border_width=1, border_color=color.gray)
if barstate.islast
    string wvfStr  = wvfSpike ? "🚨 SPIKE" : "Normal"
    color  wvfC    = wvfSpike ? color.lime : color.gray
    string crsiStr = cRSI < 10 ? "🟢 OVERSOLD" : cRSI > 90 ? "🔴 OVERBOUGHT" : str.tostring(math.round(cRSI,1))
    color  crsiC   = cRSI < 10 ? color.lime : cRSI > 90 ? color.red : color.white
    string trendStr = aboveMa200 ? "📈 Above MA200" : "📉 Below MA200"
    string signalStr= longSignal ? "✅ DUAL CONFIRM" : nearSignal ? "⚠️ NEAR" : "—"
    color  sigC     = longSignal ? color.lime : nearSignal ? color.yellow : color.gray

    table.cell(dash, 0, 0, "WVF",         text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 0, wvfStr,        text_color=wvfC,         text_size=size.small)
    table.cell(dash, 0, 1, "ConnorsRSI2", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 1, crsiStr,       text_color=crsiC,        text_size=size.small)
    table.cell(dash, 0, 2, "RSI(2)",      text_color=color.gray,   text_size=size.tiny)
    table.cell(dash, 1, 2, str.tostring(math.round(rsi2,1)), text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 0, 3, "Trend",       text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 3, trendStr,      text_color=aboveMa200?color.lime:color.red, text_size=size.small)
    table.cell(dash, 0, 4, "Signal",      text_color=color.white,  text_size=size.small)
    table.cell(dash, 1, 4, signalStr,     text_color=sigC,         text_size=size.small)

// ── Alerts ───────────────────────────────────────────────────
alertcondition(longSignal, "WVF+RSI2 DUAL CONFIRM", "✅ BOTTOM KIT: WVF + ConnorsRSI2 dual confirm")
alertcondition(wvfFired,   "WVF Fire",               "WVF: Spike dropped — watch for entry")
alertcondition(cRSI < 10,  "ConnorsRSI2 Extreme OS", "ConnorsRSI2 < 10: Extreme oversold")
