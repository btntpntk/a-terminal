// ============================================================
// CPR WEEKLY + CAMARILLA PIVOTS [SET Swing S/R Map]  —  FIXED v5.1
// CPR: Central Pivot Range (Frank Ochoa / PivotBoss)
// Camarilla: Nick Scott (1989)
// Fixes: minor — all logic sound; added array length safety
// ============================================================
//@version=5
indicator("CPR Weekly + Camarilla [SET]", overlay=true)

// ── Inputs ──────────────────────────────────────────────────
showCPR   = input.bool(true, "Show CPR", group="CPR")
showCam   = input.bool(true, "Show Camarilla", group="Camarilla")
showR2S2  = input.bool(true, "Show R2/S2",     group="Camarilla")
narrowThresh = input.float(0.3, "Narrow CPR threshold (%)", group="CPR", step=0.05)
wideThresh   = input.float(0.8, "Wide CPR threshold (%)",   group="CPR", step=0.05)

// ── Fetch Previous Week's HLC ─────────────────────────────────
// lookahead_on + [1] offset = no repaint
float prevH = request.security(syminfo.tickerid, "W", high[1],  lookahead=barmerge.lookahead_on)
float prevL = request.security(syminfo.tickerid, "W", low[1],   lookahead=barmerge.lookahead_on)
float prevC = request.security(syminfo.tickerid, "W", close[1], lookahead=barmerge.lookahead_on)

// ── CPR Levels ────────────────────────────────────────────────
float pivot = (prevH + prevL + prevC) / 3
float BC    = (prevH + prevL) / 2
float TC    = (pivot - BC) + pivot

float cprWidth = pivot != 0 ? math.abs(TC - BC) / pivot * 100 : 0

// Standard Pivots
float R1 = 2 * pivot - prevL
float S1 = 2 * pivot - prevH
float R2 = pivot + (prevH - prevL)
float S2 = pivot - (prevH - prevL)

// ── Camarilla Pivots ──────────────────────────────────────────
float hlRange = prevH - prevL
float H4 = prevC + hlRange * 1.1 / 2
float H3 = prevC + hlRange * 1.1 / 4
float L3 = prevC - hlRange * 1.1 / 4
float L4 = prevC - hlRange * 1.1 / 2
float H5 = prevL != 0 ? (prevH / prevL) * prevC : na
float L5 = not na(H5) ? prevC - (H5 - prevC) : na

// ── Plots — CPR ───────────────────────────────────────────────
plot(showCPR ? TC : na, "TC (Top CPR)", color.new(color.lime, 20), 2)
plot(showCPR ? BC : na, "BC (Bot CPR)", color.new(color.lime, 20), 2)
plot(showCPR ? pivot : na, "Pivot",     color.yellow, 2)

p_tc = plot(showCPR ? TC : na, display=display.none)
p_bc = plot(showCPR ? BC : na, display=display.none)
fill(p_tc, p_bc, color.new(color.yellow, 88))

// Standard pivots
plot(showCPR ? R1 : na, "R1", color.new(color.red,  50), 1, plot.style_circles)
plot(showCPR ? S1 : na, "S1", color.new(color.lime, 50), 1, plot.style_circles)

// ── Plots — Camarilla ─────────────────────────────────────────
plot(showCam ? H4 : na, "H4", color.new(color.red,  10), 2, plot.style_stepline)
plot(showCam ? H3 : na, "H3", color.new(color.red,  40), 1, plot.style_stepline)
plot(showCam ? L3 : na, "L3", color.new(color.lime, 40), 1, plot.style_stepline)
plot(showCam ? L4 : na, "L4", color.new(color.lime, 10), 2, plot.style_stepline)

plot(showR2S2 ? R2 : na, "R2", color.new(color.orange,40), 1)
plot(showR2S2 ? S2 : na, "S2", color.new(color.teal,  40), 1)

ph4 = plot(showCam ? H4 : na, display=display.none)
pl4 = plot(showCam ? L4 : na, display=display.none)
fill(ph4, pl4, color.new(color.red, 97))

// ── Camarilla Breakout Detection ──────────────────────────────
bool camLongBreak  = ta.crossover(close,  H4)
bool camShortBreak = ta.crossunder(close, L4)
bool mrLong        = close <= L3 and close > L4
bool mrShort       = close >= H3 and close < H4

plotshape(camLongBreak,  "H4 Break", shape.triangleup,   location.belowbar, color.red,  size=size.small, text="H4")
plotshape(camShortBreak, "L4 Break", shape.triangledown, location.abovebar, color.lime, size=size.small, text="L4")
plotshape(mrLong,        "MR Long", shape.circle,       location.belowbar, color.lime, size=size.tiny)
plotshape(mrShort,       "MR Short",shape.circle,       location.abovebar, color.red,  size=size.tiny)

// ── Dashboard ─────────────────────────────────────────────────
var table dash = table.new(position.bottom_right, 2, 8,
     bgcolor=color.new(color.black,78), border_width=1, border_color=color.gray)
if barstate.islast
    string widthStr  = str.tostring(math.round(cprWidth,2)) + "%"
    string widthBias = cprWidth < narrowThresh ? "NARROW → Trending" :
                       cprWidth > wideThresh   ? "WIDE   → Choppy"   : "MEDIUM → Normal"
    color  widthCol  = cprWidth < narrowThresh ? color.lime :
                       cprWidth > wideThresh   ? color.red  : color.yellow

    table.cell(dash, 0, 0, "Weekly CPR", bgcolor=color.new(color.black,60), text_color=color.yellow, text_size=size.small)
    table.cell(dash, 1, 0, widthStr,     bgcolor=color.new(color.black,60), text_color=widthCol,    text_size=size.small)
    table.cell(dash, 0, 1, "Bias",       text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 1, widthBias,    text_color=widthCol,     text_size=size.tiny)
    table.cell(dash, 0, 2, "─── Levels ───", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 2, "CPR / Camarilla",text_color=color.gray, text_size=size.tiny)

    lvlNames  = array.from("Pivot","TC","BC","H4","H3","L3","L4")
    lvlValues = array.from(pivot, TC, BC, H4, H3, L3, L4)
    lvlCols   = array.new_color(7, color.silver)
    array.set(lvlCols, 0, color.yellow)
    array.set(lvlCols, 1, color.lime)
    array.set(lvlCols, 2, color.lime)
    array.set(lvlCols, 3, color.red)
    array.set(lvlCols, 4, color.new(color.red,40))
    array.set(lvlCols, 5, color.new(color.lime,40))
    array.set(lvlCols, 6, color.lime)

    for i = 0 to 6
        table.cell(dash, 0, i+3, array.get(lvlNames, i), text_color=array.get(lvlCols,i), text_size=size.tiny)
        table.cell(dash, 1, i+3, str.tostring(math.round(array.get(lvlValues,i),2)), text_color=array.get(lvlCols,i), text_size=size.tiny)

// ── Alerts ───────────────────────────────────────────────────
alertcondition(camLongBreak,  "Cam H4 Breakout",  "📈 Camarilla H4 Breakout — Trend mode ON")
alertcondition(camShortBreak, "Cam L4 Breakdown", "📉 Camarilla L4 Breakdown — Trend mode ON")
alertcondition(mrLong,        "Cam L3 MR Long",   "↔️ Camarilla L3 Mean-Revert Long")
alertcondition(mrShort,       "Cam H3 MR Short",  "↔️ Camarilla H3 Mean-Revert Short")
alertcondition(cprWidth < narrowThresh, "CPR Narrow", "⚡ CPR Narrow week → Expect trending week")
